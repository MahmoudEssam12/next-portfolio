# Site URL for SEO (canonical, Open Graph, sitemap). Use your production URL.
# Example: https://mahmoudessam.dev
NEXT_PUBLIC_SITE_URL=https://nextessam.vercel.app

# EmailJS (used only by the server in /api/send-email)
# Copy to .env.local and fill in your values. Never commit .env.local.
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_USER_ID=your_public_key
